<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital AI Clinical Scribe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-4">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">Hospital AI Clinical Scribe</a>
                <div class="d-flex ms-auto align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var currentProvider = Context.Items["CurrentProvider"] as Hospital_AI.Models.Provider;
                        <span class="me-3">
                            @User.Identity.Name
                            @if (currentProvider is not null)
                            {
                                <text> (@currentProvider.Name)</text>
                            }
                        </span>
                        <a class="btn btn-outline-secondary btn-sm" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut">Sign out</a>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
</body>
</html>
