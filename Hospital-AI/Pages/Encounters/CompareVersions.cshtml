@page
@model Hospital_AI.Pages.Encounters.CompareVersionsModel
@using Hospital_AI.Services
@{
    ViewData["Title"] = "Compare Note Versions";
}

@if (Model.OlderVersion is null || Model.NewerVersion is null)
{
    <p>One or both note versions could not be found.</p>
}
else
{
    var older = Model.OlderVersion;
    var newer = Model.NewerVersion;
    var patient = newer.Encounter?.Patient;

    <h1 class="display-6">Compare Note Versions</h1>
    <p class="text-muted">
        Patient: @patient?.FirstName @patient?.LastName &middot;
        Comparing version @older.VersionNumber (saved by @older.SavedByProvider?.Name on @older.SavedAtUtc.ToLocalTime())
        to version @newer.VersionNumber (saved by @newer.SavedByProvider?.Name on @newer.SavedAtUtc.ToLocalTime())
    </p>

    <div class="alert alert-info">
        <span class="badge text-bg-danger">Removed</span> lines were only in version @older.VersionNumber.
        <span class="badge text-bg-success">Added</span> lines are new in version @newer.VersionNumber.
        Unchanged lines are shown without highlighting.
    </div>

    void RenderDiffLines(List<DiffLine> diff)
    {
        if (diff.Count == 0)
        {
            <span class="text-muted">(empty)</span>
            return;
        }

        foreach (var line in diff)
        {
            var cssClass = line.Kind switch
            {
                DiffLineKind.Added => "bg-success bg-opacity-25",
                DiffLineKind.Removed => "bg-danger bg-opacity-25 text-decoration-line-through",
                _ => ""
            };
            var prefix = line.Kind switch
            {
                DiffLineKind.Added => "+ ",
                DiffLineKind.Removed => "- ",
                _ => "  "
            };
            <div class="@cssClass">@prefix@line.Text</div>
        }
    }

    <div class="mb-3">
        <label class="form-label fw-bold">Subjective</label>
        <div class="border rounded p-2" style="white-space: pre-wrap; font-family: var(--bs-font-monospace, monospace);">
            @{ RenderDiffLines(Model.SubjectiveDiff); }
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Objective</label>
        <div class="border rounded p-2" style="white-space: pre-wrap; font-family: var(--bs-font-monospace, monospace);">
            @{ RenderDiffLines(Model.ObjectiveDiff); }
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Assessment</label>
        <div class="border rounded p-2" style="white-space: pre-wrap; font-family: var(--bs-font-monospace, monospace);">
            @{ RenderDiffLines(Model.AssessmentDiff); }
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Plan</label>
        <div class="border rounded p-2" style="white-space: pre-wrap; font-family: var(--bs-font-monospace, monospace);">
            @{ RenderDiffLines(Model.PlanDiff); }
        </div>
    </div>

    <p class="mt-3"><a asp-page="./Workspace" asp-route-id="@newer.EncounterId">Back to encounter workspace</a></p>
}
