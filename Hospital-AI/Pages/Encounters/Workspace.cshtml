@page "{id:guid}"
@model Hospital_AI.Pages.Encounters.WorkspaceModel
@{
    ViewData["Title"] = "Encounter";
}

@if (Model.Encounter is null)
{
    <p>Encounter not found.</p>
}
else
{
    <h1 class="display-6">Encounter: @Model.Encounter.Patient?.FirstName @Model.Encounter.Patient?.LastName</h1>
    <p class="text-muted">DOB: @Model.Encounter.Patient?.DateOfBirth &middot; <span id="autosaveStatus">Status: @Model.Encounter.Status</span></p>

    <div id="deactivatedBanner" class="alert alert-danger" style="display:none;">
        Your account has been deactivated by an administrator. Your work up to the last
        successful save is preserved, but no further changes can be saved. Please contact
        an administrator if you believe this is an error.
    </div>

    @if (Model.IsReadOnly)
    {
        <div class="alert alert-info">You are viewing this encounter as an Admin. Only the owning provider can edit it.</div>
    }

    @if (Model.DraftSaved)
    {
        <div class="alert alert-success">Draft saved.</div>
    }

    @if (Model.NoteVersionSaved)
    {
        <div class="alert alert-success">Note saved as a new version. This encounter is now marked Saved.</div>
    }

    @if (Model.SaveNoteError is not null)
    {
        <div class="alert alert-warning">@Model.SaveNoteError</div>
    }

    <form method="post" asp-page-handler="SaveDraft" asp-route-id="@Model.Encounter.Id">
        <div class="mb-3">
            <label asp-for="TranscriptText" class="form-label">Transcript / clinical observations</label>
            <textarea asp-for="TranscriptText" id="transcriptText" class="form-control" rows="8" disabled="@Model.IsReadOnly"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="DraftNoteText" class="form-label">Draft SOAP note</label>
            <textarea asp-for="DraftNoteText" id="draftNoteText" class="form-control" rows="10" disabled="@Model.IsReadOnly"></textarea>
        </div>
        @if (!Model.IsReadOnly)
        {
            <button type="submit" class="btn btn-primary">Save draft</button>
            <button type="button" id="generateNoteBtn" class="btn btn-outline-primary">Generate note</button>
            <button type="submit" formaction="?handler=SaveNote" class="btn btn-success">Save note (finalize version)</button>
            <span id="generateStatus" class="text-muted ms-2"></span>
        }
    </form>

    @if (!Model.IsReadOnly)
    {
        <div class="card mt-4">
            <div class="card-body">
                <h5 class="card-title">ICD-10 code search</h5>
                <p class="text-muted small">Search by code or diagnosis (e.g. "diabetes", "chest pain", "J45"). Click a result to insert it into the Assessment section of the draft note.</p>
                <input type="text" id="icd10SearchInput" class="form-control mb-2" placeholder="Search ICD-10 codes..." autocomplete="off" />
                <ul id="icd10Results" class="list-group"></ul>
            </div>
        </div>
    }

    <p class="mt-3"><a asp-page="./Index">Back to encounter list</a></p>

    @if (Model.NoteVersions.Count > 0)
    {
        <h5 class="mt-4">Saved note versions</h5>
        @if (Model.NoteVersions.Count > 1)
        {
            <p class="text-muted small">Select exactly two versions below to compare them.</p>
        }
        <table class="table table-sm">
            <thead>
                <tr>
                    @if (Model.NoteVersions.Count > 1)
                    {
                        <th></th>
                    }
                    <th>Version</th>
                    <th>Saved by</th>
                    <th>Saved at</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var version in Model.NoteVersions)
                {
                    <tr>
                        @if (Model.NoteVersions.Count > 1)
                        {
                            <td><input type="checkbox" class="compare-version-checkbox" value="@version.Id" /></td>
                        }
                        <td>@version.VersionNumber</td>
                        <td>@version.SavedByProvider?.Name</td>
                        <td>@version.SavedAtUtc.ToLocalTime()</td>
                        <td><a asp-page="./ViewVersion" asp-route-id="@version.Id">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
        @if (Model.NoteVersions.Count > 1)
        {
            <button type="button" id="compareVersionsBtn" class="btn btn-outline-secondary btn-sm" disabled>Compare selected versions</button>

            <script>
                (function () {
                    const checkboxes = Array.from(document.querySelectorAll('.compare-version-checkbox'));
                    const compareBtn = document.getElementById('compareVersionsBtn');

                    function updateCompareButtonState() {
                        const checkedCount = checkboxes.filter(cb => cb.checked).length;
                        compareBtn.disabled = checkedCount !== 2;
                    }

                    checkboxes.forEach(cb => cb.addEventListener('change', updateCompareButtonState));

                    compareBtn.addEventListener('click', function () {
                        const selected = checkboxes.filter(cb => cb.checked).map(cb => cb.value);
                        if (selected.length !== 2) {
                            return;
                        }
                        window.location.href = '/Encounters/CompareVersions?fromId=' + encodeURIComponent(selected[0]) + '&toId=' + encodeURIComponent(selected[1]);
                    });
                })();
            </script>
        }
    }

    @if (!Model.IsReadOnly)
    {
        <script>
            const transcriptTextarea = document.getElementById('transcriptText');
            const draftTextarea = document.getElementById('draftNoteText');
            const autosaveStatus = document.getElementById('autosaveStatus');
            const deactivatedBanner = document.getElementById('deactivatedBanner');
            let accountDeactivated = false;

            // Thrown by saveDraftToServer() specifically when the server reports the signed-in
            // provider's account has been deactivated (HTTP 401), so callers can distinguish
            // this from a transient network/save failure and react appropriately (stop
            // retrying, show a clear message, disable further actions).
            class DeactivatedAccountError extends Error {}

            // Persists the current transcript/draft text to the server via the existing
            // "SaveDraft" page handler, without a full page reload. Used both by the explicit
            // autosave-on-typing flow (session persistence) and by "Generate note" (so
            // generation always sees the latest transcript, even if the provider never clicked
            // "Save draft" themselves).
            async function saveDraftToServer() {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const formData = new URLSearchParams();
                formData.append('__RequestVerificationToken', token);
                formData.append('TranscriptText', transcriptTextarea.value);
                formData.append('DraftNoteText', draftTextarea.value);

                const response = await fetch(window.location.pathname + '?handler=SaveDraft', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData.toString()
                });

                if (response.status === 401) {
                    throw new DeactivatedAccountError('Account deactivated.');
                }

                if (!response.ok) {
                    throw new Error('Save draft failed with status ' + response.status);
                }
            }

            // Non-happy-path: an admin can deactivate a provider's account while that provider
            // has an encounter workspace open with unsaved changes. Rather than the next
            // autosave/generate call silently failing (or the page abruptly redirecting to
            // /AccessDenied mid-edit, discarding whatever wasn't yet saved), we surface a clear,
            // persistent banner and stop all further save attempts/actions - the provider's
            // last successfully saved state remains intact in the database, but nothing typed
            // after deactivation is lost silently or resubmitted in a loop.
            function handleAccountDeactivated() {
                if (accountDeactivated) {
                    return;
                }

                accountDeactivated = true;
                clearTimeout(autosaveDebounceTimer);
                deactivatedBanner.style.display = '';
                autosaveStatus.textContent = '';
                transcriptTextarea.disabled = true;
                draftTextarea.disabled = true;

                const generateBtn = document.getElementById('generateNoteBtn');
                if (generateBtn) {
                    generateBtn.disabled = true;
                }
            }

            // Debounced autosave: persists the transcript/draft to the database ~1.5s after
            // the provider stops typing, so an in-progress draft survives a refresh, browser
            // close, or login from a different device without requiring a manual "Save draft"
            // click. Uses navigator.sendBeacon on page unload as a best-effort final flush.
            let autosaveDebounceTimer = null;
            let autosaveInFlight = false;
            let autosaveDirty = false;

            function scheduleAutosave() {
                autosaveDirty = true;
                autosaveStatus.textContent = 'Status: Unsaved changes...';
                clearTimeout(autosaveDebounceTimer);
                autosaveDebounceTimer = setTimeout(runAutosave, 1500);
            }

            async function runAutosave() {
                if (autosaveInFlight || accountDeactivated) {
                    return;
                }

                autosaveInFlight = true;
                autosaveDirty = false;

                try {
                    await saveDraftToServer();
                    autosaveStatus.textContent = 'Status: Saved';
                } catch (error) {
                    if (error instanceof DeactivatedAccountError) {
                        handleAccountDeactivated();
                        return;
                    }
                    autosaveStatus.textContent = 'Status: Autosave failed - click "Save draft" manually.';
                } finally {
                    autosaveInFlight = false;
                    if (autosaveDirty && !accountDeactivated) {
                        scheduleAutosave();
                    }
                }
            }

            transcriptTextarea.addEventListener('input', scheduleAutosave);
            draftTextarea.addEventListener('input', scheduleAutosave);

            // Best-effort final save if the tab is closed/navigated away from while an
            // autosave is still pending (debounce timer hasn't fired yet).
            window.addEventListener('beforeunload', function () {
                if (autosaveDirty) {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const formData = new URLSearchParams();
                    formData.append('__RequestVerificationToken', token);
                    formData.append('TranscriptText', transcriptTextarea.value);
                    formData.append('DraftNoteText', draftTextarea.value);
                    navigator.sendBeacon(
                        window.location.pathname + '?handler=SaveDraft',
                        new Blob([formData.toString()], { type: 'application/x-www-form-urlencoded' }));
                }
            });

            document.getElementById('generateNoteBtn').addEventListener('click', async function () {
                const button = this;
                const status = document.getElementById('generateStatus');

                button.disabled = true;
                status.textContent = 'Saving transcript...';

                // Persist the current transcript/draft text first so "Generate note" works
                // immediately after pasting a transcript, without requiring a separate
                // "Save draft" click.
                clearTimeout(autosaveDebounceTimer);
                try {
                    await saveDraftToServer();
                    autosaveDirty = false;
                    autosaveStatus.textContent = 'Status: Saved';
                } catch (error) {
                    if (error instanceof DeactivatedAccountError) {
                        handleAccountDeactivated();
                        button.disabled = true;
                        status.textContent = '';
                        return;
                    }
                    status.textContent = 'Failed to save transcript before generating.';
                    button.disabled = false;
                    return;
                }

                status.textContent = 'Generating...';
                draftTextarea.value = '';

                const encounterId = '@Model.Encounter.Id';
                const eventSource = new EventSource(`/api/encounters/${encounterId}/generate-note`);

                eventSource.onmessage = function (event) {
                    draftTextarea.value += event.data.replace(/\\n/g, '\n');
                };

                eventSource.addEventListener('done', function () {
                    eventSource.close();
                    button.disabled = false;
                    status.textContent = 'Generation complete. Review and save the draft.';
                    scheduleAutosave();
                });

                eventSource.onerror = function () {
                    eventSource.close();
                    button.disabled = false;
                    status.textContent = 'Generation stopped (connection closed).';
                };
            });

            // ICD-10 search widget: debounced free-text search against the local API, with
            // results inserted into the draft note's Assessment section on click.

            // Inserts a code under an "ICD-10 Codes:" sub-header within the Assessment section
            // (mirrors the section boundaries used server-side by SoapNoteParser), so saved
            // NoteVersions persist the code as part of Assessment rather than trailing Plan text.
            function insertIcd10CodeIntoAssessment(code, description) {
                const text = draftTextarea.value;
                const bulletLine = `- ${code} - ${description}`;
                const sectionHeaderRegex = /^\s*\**\s*(Subjective|Objective|Assessment|Plan)\s*\**\s*:\s*\**\s*/gim;

                let assessmentStart = -1;
                let assessmentContentStart = -1;
                let nextSectionStart = text.length;
                let match;

                while ((match = sectionHeaderRegex.exec(text)) !== null) {
                    if (assessmentStart === -1 && match[1].toLowerCase() === 'assessment') {
                        assessmentStart = match.index;
                        assessmentContentStart = match.index + match[0].length;
                    } else if (assessmentStart !== -1) {
                        nextSectionStart = match.index;
                        break;
                    }
                }

                if (assessmentStart === -1) {
                    // No Assessment header yet - create one at the end of the note.
                    const separator = (text.endsWith('\n') || text.length === 0) ? '' : '\n';
                    draftTextarea.value = text + `${separator}\nAssessment:\nICD-10 Codes:\n${bulletLine}\n`;
                } else {
                    const assessmentContent = text.slice(assessmentContentStart, nextSectionStart);
                    const hasHeader = assessmentContent.includes('ICD-10 Codes:');
                    const trimmedContent = assessmentContent.replace(/\s+$/, '');
                    const newContent = hasHeader
                        ? `${trimmedContent}\n${bulletLine}\n`
                        : `${trimmedContent}\nICD-10 Codes:\n${bulletLine}\n`;

                    draftTextarea.value = text.slice(0, assessmentContentStart) + newContent + text.slice(nextSectionStart);
                }

                // Trigger the same debounced autosave used for manual typing, since this
                // programmatic edit doesn't naturally fire an 'input' event.
                scheduleAutosave();
            }

            const icd10Input = document.getElementById('icd10SearchInput');
            const icd10Results = document.getElementById('icd10Results');
            let icd10DebounceTimer = null;

            icd10Input.addEventListener('input', function () {
                clearTimeout(icd10DebounceTimer);
                const query = this.value.trim();

                if (query.length === 0) {
                    icd10Results.innerHTML = '';
                    return;
                }

                icd10DebounceTimer = setTimeout(async () => {
                    const response = await fetch(`/api/icd10codes/search?q=${encodeURIComponent(query)}`);
                    const codes = await response.json();

                    icd10Results.innerHTML = '';
                    codes.forEach(item => {
                        const li = document.createElement('li');
                        li.className = 'list-group-item list-group-item-action';
                        li.style.cursor = 'pointer';
                        li.textContent = `${item.code} - ${item.description}`;
                        li.addEventListener('click', () => {
                            insertIcd10CodeIntoAssessment(item.code, item.description);
                        });
                        icd10Results.appendChild(li);
                    });
                }, 300);
            });
        </script>
    }
}
