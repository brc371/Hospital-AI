@page "{id:guid}"
@model Hospital_AI.Pages.Encounters.ViewVersionModel
@{
    ViewData["Title"] = "Note Version";
}

@if (Model.NoteVersion is null)
{
    <p>Note version not found.</p>
}
else
{
    var version = Model.NoteVersion;
    var patient = version.Encounter?.Patient;

    <h1 class="display-6">Note Version @version.VersionNumber</h1>
    <p class="text-muted">
        Patient: @patient?.FirstName @patient?.LastName &middot;
        Saved by @version.SavedByProvider?.Name on @version.SavedAtUtc.ToLocalTime()
    </p>

    <div class="alert alert-info">
        This is a read-only view of a saved note version. Saved note versions are immutable and
        cannot be edited.
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Subjective</label>
        <div class="border rounded p-2 bg-light" style="white-space: pre-wrap;">@version.Subjective</div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Objective</label>
        <div class="border rounded p-2 bg-light" style="white-space: pre-wrap;">@version.Objective</div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Assessment</label>
        <div class="border rounded p-2 bg-light" style="white-space: pre-wrap;">@version.Assessment</div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Plan</label>
        <div class="border rounded p-2 bg-light" style="white-space: pre-wrap;">@version.Plan</div>
    </div>

    <p class="mt-3"><a asp-page="./Workspace" asp-route-id="@version.EncounterId">Back to encounter workspace</a></p>
}
