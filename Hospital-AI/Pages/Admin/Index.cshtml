@page
@model Hospital_AI.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1 class="display-6">Admin Dashboard</h1>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" asp-page="/Admin/Index">All Encounters</a></li>
    <li class="nav-item"><a class="nav-link" asp-page="/Admin/Providers">Providers</a></li>
    <li class="nav-item"><a class="nav-link" asp-page="/Admin/Templates">Note Templates</a></li>
</ul>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label asp-for="ProviderId" class="form-label">Provider</label>
        <select asp-for="ProviderId" class="form-select">
            <option value="">All providers</option>
            @foreach (var provider in Model.Providers)
            {
                <option value="@provider.Id">@provider.Name</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label asp-for="FromDate" class="form-label">From</label>
        <input asp-for="FromDate" type="date" class="form-control" />
    </div>
    <div class="col-auto">
        <label asp-for="ToDate" class="form-label">To</label>
        <input asp-for="ToDate" type="date" class="form-control" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-page="/Admin/Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (Model.Encounters.Count == 0)
{
    <p class="text-muted">No encounters match the current filters.</p>
}
else
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Provider</th>
                <th>Status</th>
                <th>Created</th>
                <th>Last updated</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var encounter in Model.Encounters)
            {
                <tr>
                    <td>@encounter.Patient?.FirstName @encounter.Patient?.LastName</td>
                    <td>@encounter.Provider?.Name</td>
                    <td>@encounter.Status</td>
                    <td>@encounter.CreatedAtUtc.ToLocalTime()</td>
                    <td>@encounter.UpdatedAtUtc.ToLocalTime()</td>
                    <td><a asp-page="/Encounters/Workspace" asp-route-id="@encounter.Id">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}
