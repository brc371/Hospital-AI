@page
@model Hospital_AI.Pages.Admin.TemplatesModel
@{
    ViewData["Title"] = "Note Templates";
}

<h1 class="display-6">Admin Dashboard</h1>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link" asp-page="/Admin/Index">All Encounters</a></li>
    <li class="nav-item"><a class="nav-link" asp-page="/Admin/Providers">Providers</a></li>
    <li class="nav-item"><a class="nav-link active" asp-page="/Admin/Templates">Note Templates</a></li>
</ul>

@if (Model.SaveError is not null)
{
    <div class="alert alert-warning">@Model.SaveError</div>
}

<table class="table table-sm">
    <thead>
        <tr>
            <th>Name</th>
            <th>Active</th>
            <th>Last updated</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var template in Model.Templates)
        {
            <tr>
                <td>@template.Name</td>
                <td>@(template.IsActive ? "Yes" : "No")</td>
                <td>@template.UpdatedAtUtc.ToLocalTime()</td>
                <td>
                    <a asp-page="/Admin/Templates" asp-route-editId="@template.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@template.Id" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this template?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<h5 class="mt-4">@(Model.EditId is null ? "Create template" : "Edit template")</h5>
<form method="post" asp-page-handler="@(Model.EditId is null ? "Create" : "Update")" asp-route-id="@Model.EditId">
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. Orthopedic Follow-up" />
    </div>
    <div class="mb-3">
        <label asp-for="PromptText" class="form-label">Prompt instructions</label>
        <textarea asp-for="PromptText" class="form-control" rows="6" placeholder="Instructions injected into the AI system prompt to shape note generation for this encounter type."></textarea>
    </div>
    @if (Model.EditId is not null)
    {
        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <label asp-for="IsActive" class="form-check-label">Active (selectable by providers)</label>
        </div>
    }
    <button type="submit" class="btn btn-primary">@(Model.EditId is null ? "Create template" : "Save changes")</button>
    @if (Model.EditId is not null)
    {
        <a asp-page="/Admin/Templates" class="btn btn-outline-secondary">Cancel</a>
    }
</form>
